<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | SIP - Universitas Andalas</title>
    <link rel="stylesheet" href="https://unpkg.com/basecoat/css/basecoat.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            color: #1f2937;
            background: #fff;
        }

        /* ============ WRAPPER ============ */
        .page {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ============ PANEL KIRI ============ */
        .panel-left {
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 40%;
            flex-shrink: 0;
            position: relative;
            background-color: #004921;
            overflow: hidden;
            padding: 3rem;
        }

        @media (min-width: 1024px) {
            .panel-left { display: flex; }
        }

        .panel-left::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/img/suasana.png') center / cover no-repeat;
            opacity: 0.35;
        }

        .panel-left-content {
            position: relative;
            z-index: 1;
            color: #fff;
            max-width: 340px;
        }

        .panel-left-content h1 {
            font-size: 1.85rem;
            font-weight: 700;
            line-height: 1.35;
            margin-bottom: 1rem;
            color: #fff;
        }

        .panel-left-content > p {
            font-size: 0.875rem;
            line-height: 1.75;
            color: rgba(255,255,255,0.82);
            margin-bottom: 2rem;
        }

        .feature-box {
            display: flex;
            align-items: flex-start;
            gap: 0.875rem;
            padding: 1.125rem 1.25rem;
            background: rgba(0,0,0,0.22);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 0.875rem;
        }

        .feature-box .material-symbols-outlined {
            font-size: 1.75rem;
            color: #86efac;
            flex-shrink: 0;
            line-height: 1;
        }

        .feature-box h3 {
            font-size: 0.9rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.25rem;
        }

        .feature-box p {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.62);
            line-height: 1.5;
        }

        /* ============ PANEL KANAN ============ */
        .panel-right {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-y: auto;
            padding: 2.5rem 1.5rem;
            background: #fff;
        }

        .form-container {
            width: 100%;
            max-width: 420px;
        }

        /* Header logo */
        .brand-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2.5rem;
        }

        .brand-header img {
            height: 60px;
            width: auto;
            object-fit: contain;
        }

        .brand-header-text {
            border-left: 2px solid #e5e7eb;
            padding-left: 1rem;
        }

        .brand-header-text h2 {
            font-size: 1rem;
            font-weight: 700;
            color: #004921;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            line-height: 1.25;
        }

        /* Greeting */
        .greeting {
            margin-bottom: 1.75rem;
        }

        .greeting h3 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 0.375rem;
        }

        .greeting p {
            font-size: 0.85rem;
            color: #6b7280;
        }

        /* Form card */
        .form-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 1rem;
            padding: 1.75rem;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        /* Error alert */
        .alert {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 0.625rem;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.83rem;
            color: #dc2626;
        }

        .alert .material-symbols-outlined {
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        /* Field group */
        .field {
            margin-bottom: 1.125rem;
        }

        .field-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.4rem;
        }

        label {
            display: block;
            font-size: 0.68rem;
            font-weight: 700;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .forgot {
            font-size: 0.75rem;
            font-weight: 700;
            color: #004921;
            text-decoration: none;
        }

        .forgot:hover { text-decoration: underline; }

        /* Input dengan ikon */
        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrap .ico {
            position: absolute;
            left: 0.75rem;
            font-size: 1.1rem;
            color: #d1d5db;
            pointer-events: none;
            user-select: none;
            transition: color 0.15s;
            /* Material Symbols specific */
            font-family: 'Material Symbols Outlined';
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            line-height: 1;
        }

        .input-wrap:focus-within .ico {
            color: #004921;
        }

        .input-wrap input {
            width: 100%;
            height: 46px;
            padding: 0 1rem 0 2.5rem;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 0.625rem;
            font-size: 0.875rem;
            font-family: 'Inter', sans-serif;
            color: #111827;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
            -webkit-appearance: none;
            appearance: none;
        }

        .input-wrap input::placeholder {
            color: #d1d5db;
        }

        .input-wrap input:focus {
            border-color: #004921;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(0,73,33,0.1);
        }

        /* Remember */
        .remember {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 0.25rem;
        }

        .remember input[type="checkbox"] {
            width: 15px;
            height: 15px;
            accent-color: #004921;
            cursor: pointer;
            flex-shrink: 0;
        }

        .remember label {
            font-size: 0.78rem;
            font-weight: 400;
            color: #6b7280;
            text-transform: none;
            letter-spacing: 0;
            cursor: pointer;
        }

        /* Submit button */
        .btn-submit {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            width: 100%;
            height: 48px;
            margin-top: 1.25rem;
            background: #004921;
            color: #fff;
            border: none;
            border-radius: 0.625rem;
            font-size: 0.9rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(0,73,33,0.28);
            transition: background 0.15s, transform 0.1s;
        }

        .btn-submit:hover { background: #106332; }
        .btn-submit:active { transform: scale(0.98); }

        .btn-submit .material-symbols-outlined {
            font-size: 1.1rem;
        }

        /* Divider */
        .or-divider {
            position: relative;
            text-align: center;
            margin: 1.5rem 0;
        }

        .or-divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #f3f4f6;
        }

        .or-divider span {
            position: relative;
            background: #fff;
            padding: 0 0.875rem;
            font-size: 0.65rem;
            font-weight: 700;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.12em;
        }

        /* Google button */
        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.625rem;
            width: 100%;
            height: 44px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 0.625rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: #374151;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background 0.15s;
        }

        .btn-google:hover { background: #f9fafb; }

        .btn-google img {
            width: 16px;
            height: 16px;
        }

        /* Footer */
        .form-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1.75rem;
            padding-top: 1.25rem;
            border-top: 1px solid #f3f4f6;
        }

        .form-footer p {
            font-size: 0.7rem;
            color: #9ca3af;
        }

        .footer-nav {
            display: flex;
            gap: 1rem;
        }

        .footer-nav a {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #9ca3af;
            text-decoration: none;
        }

        .footer-nav a:hover { color: #004921; }
    </style>
</head>
<body>

<div class="page">

    <!-- ===== PANEL KIRI ===== -->
    <aside class="panel-left">
        <div class="panel-left-content">
            <h1>Kelola Pengadaan Jadi Lebih Mudah.</h1>
            <p>
                Sistem Informasi Pengadaan (SIP) Universitas Andalas hadir untuk
                transparansi dan efisiensi birokrasi kampus.
            </p>
        </div>
    </aside>

    <!-- ===== PANEL KANAN ===== -->
    <main class="panel-right">
        <div class="form-container">

            <!-- Brand header -->
            <div class="brand-header">
                <img src="/img/logo-unand.png" alt="Logo Universitas Andalas">
                <div class="brand-header-text">
                    <h2>Universitas<br>Andalas</h2>
                </div>
            </div>

            <!-- Greeting -->
            <div class="greeting">
                <h3>Selamat Datang</h3>
                <p>Silakan masuk dengan akun resmi SIP Anda.</p>
            </div>

            <!-- Form card -->
            <div class="form-card">

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert">
                    <span class="material-symbols-outlined">error</span>
                    <%= error %>
                </div>
                <% } %>

                <form method="POST" action="/login" novalidate>

                    <div class="field">
                        <label for="email">Username / Email</label>
                        <div class="input-wrap">
                            <span class="ico">person</span>
                            <input type="email" id="email" name="email"
                                placeholder="Masukkan email resmi Anda"
                                autocomplete="email" required>
                        </div>
                    </div>

                    <div class="field">
                        <div class="field-meta">
                            <label for="password">Kata Sandi</label>
                            <a class="forgot" href="#">Lupa Sandi?</a>
                        </div>
                        <div class="input-wrap">
                            <span class="ico">lock</span>
                            <input type="password" id="password" name="password"
                                placeholder="Masukkan kata sandi"
                                autocomplete="current-password" required>
                        </div>
                    </div>

                    <div class="remember">
                        <input type="checkbox" id="remember" name="remember">
                        <label for="remember">Tetap masuk selama 30 hari</label>
                    </div>

                    <button type="submit" class="btn-submit">
                        Masuk Sekarang
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>

                </form>

            </div>

            <!-- Footer -->
            <div class="form-footer">
                <p>&copy; 2026 Kelompok B9 PWEB</p>
            </div>

        </div>
    </main>

</div>

</body>
</html>
