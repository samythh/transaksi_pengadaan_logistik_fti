<div>
    <h2 class="mb-3">Dashboard Utama</h2>
    
    <div class="card mb-4 hero-card">
        <h3 class="mt-0 text-dark">
            Selamat Datang, <%= typeof nama !== 'undefined' ? nama : 'Pengguna' %>! 👋
        </h3>
        <p class="mb-0 text-md">
            Anda saat ini login dengan hak akses sebagai 
            <span class="badge badge-primary text-sm">
                <%= typeof role !== 'undefined' ? role : '-' %>
            </span>. 
            <br>
            Semua aktivitas pengadaan logistik dan operasional Anda akan direkam oleh sistem.
        </p>
    </div>

    <hr class="mb-4">

    <h4 class="mb-3">Akses Cepat Modul</h4>
    <div class="row">
        
        <% if (typeof role !== 'undefined' && (role === 'Admin' || role === 'admin')) { %>
            
            <div class="col-4">
                <div class="card text-center" style="padding: 20px;">
                    <h1 class="card-icon">📝</h1>
                    <h5 class="mt-2 mb-1">Pengajuan Baru</h5>
                    <p class="text-muted card-desc">Buat atau kelola draf permintaan pengadaan barang.</p>
                    <a href="/pengadaan" class="btn btn-sm btn-outline btn-block">Buka Modul</a>
                </div>
            </div>

            <div class="col-4">
                <div class="card text-center card-highlight" style="padding: 20px;">
                    <h1 class="card-icon">📄</h1>
                    <h5 class="mt-2 mb-1 text-primary">Purchase Order</h5>
                    <p class="text-muted card-desc">Cetak surat pesanan resmi ke vendor (PDF).</p>
                    <a href="/po" class="btn btn-sm btn-primary btn-block">Buka Modul</a>
                </div>
            </div>

            <div class="col-4">
                <div class="card text-center" style="padding: 20px;">
                    <h1 class="card-icon">📦</h1>
                    <h5 class="mt-2 mb-1">Stok & Gudang</h5>
                    <p class="text-muted card-desc">Catat penerimaan barang dan pantau stok kritis.</p>
                    <a href="/stok" class="btn btn-sm btn-outline btn-block">Buka Modul</a>
                </div>
            </div>

        <% } else if (typeof role !== 'undefined' && (role === 'Wakil Dekan' || role === 'wadir')) { %>
            
            <div class="col-4">
                <div class="card text-center card-highlight" style="padding: 20px;">
                    <h1 class="card-icon">✅</h1>
                    <h5 class="mt-2 mb-1 text-primary">Persetujuan Pengadaan</h5>
                    <p class="text-muted card-desc">Tinjau dan setujui permintaan barang dari Admin.</p>
                    <a href="/pengadaan" class="btn btn-sm btn-primary btn-block">Buka Modul</a>
                </div>
            </div>

        <% } %>

    </div>
</div>